# ────────────────────────────────────────────────
# SERVER
# ────────────────────────────────────────────────

# Porta su cui ascolta il backend Express
PORT=3000

# URL pubblico dell'applicazione (usato nei link generati dal backend, es. link alla foto dopo la pubblicazione)
PUBLIC_BASE_URL=https://fotosicai.montagnaservizi.it

# Porta host su cui esporre il frontend Docker (porta container sempre 80)
FRONTEND_HOST_PORT=8080

# ────────────────────────────────────────────────
# DATABASE & STORAGE
# ────────────────────────────────────────────────

# Percorso del file SQLite (relativo alla working directory del backend)
DATABASE_PATH=./db/fotosicai.sqlite

# Directory dove vengono salvate le immagini caricate (original, medium, thumb)
STORAGE_DIR=./storage

# ────────────────────────────────────────────────
# INTELLIGENZA ARTIFICIALE (Anthropic Claude)
# ────────────────────────────────────────────────

# Chiave API Anthropic — obbligatoria per la generazione di titolo e descrizione
ANTHROPIC_API_KEY=sk-ant-...

# Modello Claude da usare per la vision (default: claude-sonnet-4-6)
AI_MODEL=claude-sonnet-4-6

# ────────────────────────────────────────────────
# AMMINISTRAZIONE
# ────────────────────────────────────────────────

# Token bearer per gli endpoint admin (es. DELETE /api/admin/images/:id) — cambiare in produzione
ADMIN_TOKEN=changeme

# ────────────────────────────────────────────────
# GEOCODING (Nominatim / OpenStreetMap)
# ────────────────────────────────────────────────

# URL base del servizio di reverse geocoding
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org/reverse

# User-Agent da inviare nelle richieste a Nominatim (obbligatorio per policy OSM)
NOMINATIM_USER_AGENT=fotosicai/1.0 (admin@example.it)

# ────────────────────────────────────────────────
# CONSENSO
# ────────────────────────────────────────────────

# Versione del documento di consenso (formato YYYY-MM-DD) — salvata in DB per ogni foto
CONSENT_VERSION=2026-04-30

# ────────────────────────────────────────────────
# EMAIL (verifica indirizzo autore)
# ────────────────────────────────────────────────

# SMTP per invio mail di verifica.
# Locale (mailpit via docker compose --profile dev): SMTP_HOST=mailpit, SMTP_PORT=1025, no auth
# Produzione (Gmail): SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false, user + app password
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Foto SICAI <noreply@fotosicai.it>"

# Giorni di fiducia: un'email già verificata entro questa finestra pubblica direttamente senza nuova conferma
EMAIL_VERIFICATION_TRUST_DAYS=30

# Validità del singolo link di verifica (ore)
EMAIL_VERIFICATION_TTL_HOURS=24

# ────────────────────────────────────────────────
# FRONTEND (variabili VITE_* — iniettate nel bundle a build-time)
# ────────────────────────────────────────────────

# Ambiente applicativo — mostrato nel popup Info come badge PROD/DEV
VITE_APP_ENV=production

# URL del tile server cartografico (formato Leaflet con {z}/{x}/{y})
VITE_TILE_URL=https://api.webmapp.it/tiles/{z}/{x}/{y}.png

# Stringa di attribuzione mostrata in mappa
VITE_TILE_ATTRIBUTION=&copy; CAI &copy; OpenStreetMap

# Distanza massima (in metri) dal tracciato SICAI entro cui una foto è associata a una tappa.
# Usata sia dal backend (stage matching) sia dal frontend (raggio del cerchio sulla mappa).
VITE_STAGE_MAX_DISTANCE_M=5000

# URL base delle pagine tappa sul sito ufficiale SICAI (completato con il ref tappa in minuscolo, es. "l13")
VITE_SICAI_TRACK_BASE_URL=https://sentieroitalia.cai.it/track/si-
