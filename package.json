{
  "name": "fotosicai",
  "version": "1.2.0",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev --workspace=apps/backend\" \"npm run dev --workspace=apps/frontend\"",
    "build": "npm run build --workspace=apps/frontend",
    "start": "npm run start --workspace=apps/backend",
    "reset": "bash scripts/reset.sh"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
